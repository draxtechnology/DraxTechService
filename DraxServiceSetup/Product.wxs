<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="Drax Technology Service"
           Manufacturer="Drax Technology"
           Version="1.0.2"
           UpgradeCode="B5758DCA-6BC5-4E2C-BF55-7FA118631F65"
           Scope="perMachine"
           InstallerVersion="500">

    <SummaryInformation Description="Drax Technology Network Manager"
                        Keywords="Installer,Drax,NetworkManager" />

    <MajorUpgrade DowngradeErrorMessage="A later version of [ProductName] is already installed." />

    <Media Id="1" Cabinet="files.cab" EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="DraxService.ico" SourceFile="..\Drax360NetworkManager\DT-small.ico" />
    <Property Id="ARPPRODUCTICON" Value="DraxService.ico" />

    <!-- The service targets net10.0-windows. The .NET 10 Runtime is not
         gated here — pair this MSI with a bootstrapper bundle (mirroring
         DraxTechClient/DraxClientSetup) when shipping to a fresh machine. -->

    <Feature Id="Main" Title="Drax Technology Service" Level="1">
      <ComponentGroupRef Id="ServiceComponents" />
      <ComponentGroupRef Id="DependencyFiles" />
      <ComponentGroupRef Id="IniFiles" />
      <ComponentGroupRef Id="WinRuntimeFiles" />
    </Feature>

    <!-- Standard wizard with a "change install folder" page. WiX 5 requires
         the namespaced <ui:WixUI> form; UIRef is rejected for dialog sets.
         InstallDirectory authors the WIXUI_INSTALLDIR property automatically. -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- C:\AMX1\ as install location, with ini\ subfolder and the
         runtimes\win\lib\net10.0\ subtree that the .NET runtime expects
         for RID-specific NuGet assets (ServiceController, EventLog, etc.).
         The leaf folder name must match the TFM in Drax360Service.csproj —
         the runtime resolves it literally from runtimeTargets in deps.json. -->
    <StandardDirectory Id="TARGETDIR">
      <Directory Id="INSTALLFOLDER" Name="AMX1">
        <Directory Id="IniFolder" Name="ini" />
        <Directory Id="RuntimesDir" Name="runtimes">
          <Directory Id="RuntimesWinDir" Name="win">
            <Directory Id="RuntimesWinLibDir" Name="lib">
              <Directory Id="WinRuntimeDir" Name="net10.0" />
            </Directory>
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Service component: holds the EXE + service install/control -->
    <ComponentGroup Id="ServiceComponents" Directory="INSTALLFOLDER">
      <Component Id="DraxTechnologyExe" Guid="A1B5C2D3-4E5F-6A7B-8C9D-0E1F2A3B4C5D">
        <!-- On .NET (Core) the exe is the apphost; the managed assembly + config
             (DraxTechnology.dll, .dll.config, .deps.json, .runtimeconfig.json)
             are picked up by the auto-generated Files.wxs DependencyFiles
             group. -->
        <File Id="DraxTechnology.exe"
              Source="$(var.Drax360Service.TargetDir)DraxTechnology.exe"
              KeyPath="yes" />
        <!-- Register the event source while the MSI is elevated. The service
             runs as LocalService and cannot create it at runtime. -->
        <util:EventSource Name="Drax360"
                          Log="Service"
                          EventMessageFile="[WindowsFolder]Microsoft.NET\Framework64\v4.0.30319\EventLogMessages.dll" />
        <!-- ServiceBase.EventLog uses the service name as source in the Application log -->
        <util:EventSource Name="DraxTechnology"
                          Log="Application"
                          EventMessageFile="[WindowsFolder]Microsoft.NET\Framework64\v4.0.30319\EventLogMessages.dll" />
        <ServiceInstall Id="DraxTechnologyService"
                        Name="DraxTechnology"
                        DisplayName="Drax Technology Service"
                        Description="Drax Technology Network Manager"
                        Type="ownProcess"
                        Start="demand"
                        ErrorControl="normal"
                        Account="NT AUTHORITY\LocalService"
                        Vital="yes" />
        <ServiceControl Id="DraxTechnologyServiceControl"
                        Name="DraxTechnology"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
    </ComponentGroup>

  </Package>

</Wix>
