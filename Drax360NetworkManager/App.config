<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="Panels" value="U2FsdGVkX191GGJ/bumkNXbg8/TxbEI=" />
    <add key="Configuration" value="c:\AMX1" />
    <!-- build temp, log, ini under this foler -->
    <add key="FakeMode" value="1" />
    <!-- 0 = off, 1 = on -->
    <!-- AMX instance / port. A site can run up to four managers in parallel;
         this C# service may occupy any of the four slots.
           AmxInstance = 1..4  -> port 3090..3093 (AMX1=3090, AMX2=3091, ...)
           AmxPort     = explicit port, overrides AmxInstance if both set.
         Omit both to default to 3090 (AMX1). -->
    <!-- <add key="AmxInstance" value="1" /> -->
    <!-- <add key="AmxPort" value="3090" /> -->
    <!-- MQTT mirror for the open head-end / Node-RED PoC. Additive and parallel to
         AMX: when enabled, every normalised event is also published as JSON to a
         local broker. Off by default so a normal install behaves exactly as before.
           MqttEnabled     false = off (default), true = on
           MqttBroker      broker host (default localhost — self-contained, no internet)
           MqttPort        broker TCP port (default 1883)
           MqttTopicPrefix root topic; events -> <prefix>/<panel>/event,
                           log -> <prefix>/<panel>/log, controls in <- <prefix>/<panel>/cmd -->
    <add key="MqttEnabled" value="false" />
    <add key="MqttBroker" value="localhost" />
    <add key="MqttPort" value="1883" />
    <add key="MqttTopicPrefix" value="drax" />
    <!-- Fallback for AMX shutdown. The client exits when AMX sends NWM:END at
         close (legacy NWM parity). If a site's AMX build closes its socket
         without sending END (check the service trace: "Received From AMX:"
         lines followed by "AMX link down"), enable this and the service will
         forward NWM:END to the client itself when the AMX TCP link drops.
         Off by default: a link drop also happens on an AMX crash or restart,
         not just a deliberate close, and closing the operator's client on a
         crash may not be wanted.
           CloseClientOnAmxLoss  false = off (default), true = on -->
    <add key="CloseClientOnAmxLoss" value="false" />
  </appSettings>
</configuration>
