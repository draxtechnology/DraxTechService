<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net481</TargetFramework>
    <RootNamespace>DraxTechnology</RootNamespace>
    <AssemblyName>DraxTechnology</AssemblyName>
    <LangVersion>8.0</LangVersion>
    <StartupObject>DraxTechnology.Program</StartupObject>
    <AutoGenerateBindingRedirects>false</AutoGenerateBindingRedirects>
    <GenerateBindingRedirectsOutputType>false</GenerateBindingRedirectsOutputType>
    <Deterministic>true</Deterministic>
    <ProjectGuid>{040A3342-B92B-4794-B3F9-DB63B796BD30}</ProjectGuid>
    <!-- Properties/AssemblyInfo.cs is the source of truth — don't let SDK auto-generate one. -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="System.Configuration" />
    <Reference Include="System.Configuration.Install" />
    <Reference Include="System.Management" />
    <Reference Include="System.ServiceProcess" />
    <Reference Include="System.Web.Extensions" />
  </ItemGroup>

  <ItemGroup>
    <!-- EF Core 3.1.32 is the last version supporting .NET Framework 4.8.1 (netstandard2.0). -->
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.7" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="3.1.32" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="3.1.32" />
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="3.0.2" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="DraxService.Designer.cs">
      <DependentUpon>DraxService.cs</DependentUpon>
    </Compile>
    <Compile Update="ProjectInstaller.Designer.cs">
      <DependentUpon>ProjectInstaller.cs</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="DraxService.resx">
      <DependentUpon>DraxService.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="ProjectInstaller.resx">
      <DependentUpon>ProjectInstaller.cs</DependentUpon>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <None Update="ini\AdvMan.ini" CopyToOutputDirectory="PreserveNewest" />
    <None Update="ini\EMLMan.ini" CopyToOutputDirectory="PreserveNewest" />
    <None Update="ini\GenMan.ini" CopyToOutputDirectory="PreserveNewest" />
    <None Update="ini\MAXMan.ini" CopyToOutputDirectory="PreserveNewest" />
    <None Update="ini\Takman.ini" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- Always copy App.config → exe.config so editing App.config in VS takes effect
       on the next Build without needing a Rebuild. AutoGenerateBindingRedirects is
       off because the redirects are authored directly in App.config. -->
  <Target Name="SyncAppConfig" AfterTargets="Build">
    <Copy SourceFiles="$(MSBuildProjectDirectory)\App.config"
          DestinationFiles="$(OutputPath)$(AssemblyName).exe.config"
          ContinueOnError="true" />
  </Target>

  <!-- SQLitePCLRaw.lib.e_sqlite3's buildTransitive targets copy e_sqlite3.dll into
       runtimes\win-x64\native\ inside the output directory, but .NET Framework only
       loads native DLLs from the exe directory root. This target copies the DLL there. -->
  <Target Name="CopyNativeSQLiteToOutputRoot" AfterTargets="Build">
    <ItemGroup>
      <_NativeE_Sqlite3 Include="$(NuGetPackageRoot)sqlitepclraw.lib.e_sqlite3\**\runtimes\win-x64\native\e_sqlite3.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_NativeE_Sqlite3)" DestinationFolder="$(OutputPath)" ContinueOnError="true" />
  </Target>

</Project>
