<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>DraxTechnology</RootNamespace>
    <AssemblyName>DraxTechnology</AssemblyName>
    <StartupObject>DraxTechnology.Program</StartupObject>
    <Deterministic>true</Deterministic>
    <ProjectGuid>{040A3342-B92B-4794-B3F9-DB63B796BD30}</ProjectGuid>
    <!-- Properties/AssemblyInfo.cs is the source of truth — don't let SDK auto-generate one. -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <!-- Service is Windows-only by design (ServiceBase, EventLog, WMI, named-pipe ACLs).
         CA1416 fires for Windows-only APIs even though our TFM is net10.0-windows. -->
    <NoWarn>$(NoWarn);CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.0.9" />
    <!-- MQTT publisher (MqttTransfer.cs) — mirrors the normalised event stream to a
         local broker for the open head-end / Node-RED PoC. Off unless MqttEnabled=true;
         the live AMX path is untouched either way. -->
    <PackageReference Include="MQTTnet" Version="5.2.0.1603" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.9" />
    <!-- Direct ref overrides the SQLitePCLRaw.lib.e_sqlite3 2.1.11 that EF Core 10.0.7
         pulls in transitively, which carries a known high-severity vuln (NU1903 /
         GHSA-2m69-gcr7-jv3q). 3.50.3 bundles a patched SQLite native library. -->
    <PackageReference Include="SQLitePCLRaw.lib.e_sqlite3" Version="3.50.3" />
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="10.0.9" />
    <PackageReference Include="System.Diagnostics.EventLog" Version="10.0.9" />
    <PackageReference Include="System.IO.Ports" Version="10.0.9" />
    <PackageReference Include="System.Management" Version="10.0.9" />
    <PackageReference Include="System.ServiceProcess.ServiceController" Version="10.0.9" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="DraxService.Designer.cs">
      <DependentUpon>DraxService.cs</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="DraxService.resx">
      <DependentUpon>DraxService.cs</DependentUpon>
    </EmbeddedResource>
  </ItemGroup>

  <!-- Copy the win-x64 native SQLite to the output root so the WiX harvest
       (DraxServiceSetup\Regenerate-Files.ps1) picks it up alongside the
       managed DLLs. .NET would otherwise probe runtimes\win-x64\native\
       only, but the installer would need to mirror that subtree. -->
  <Target Name="CopyNativeSQLiteToOutputRoot" AfterTargets="Build">
    <Copy SourceFiles="$(OutputPath)runtimes\win-x64\native\e_sqlite3.dll" DestinationFolder="$(OutputPath)" ContinueOnError="true" />
  </Target>

</Project>
