<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>DraxTechnology</RootNamespace>
    <AssemblyName>DraxTechnology</AssemblyName>
    <StartupObject>DraxTechnology.Program</StartupObject>
    <Deterministic>true</Deterministic>
    <ProjectGuid>{040A3342-B92B-4794-B3F9-DB63B796BD30}</ProjectGuid>
    <!-- Properties/AssemblyInfo.cs is the source of truth — don't let SDK auto-generate one. -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <!-- Service is Windows-only by design (ServiceBase, EventLog, WMI, named-pipe ACLs).
         CA1416 fires for Windows-only APIs even though our TFM is net8.0-windows. -->
    <NoWarn>$(NoWarn);CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.10" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="8.0.10" />
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="8.0.1" />
    <PackageReference Include="System.Diagnostics.EventLog" Version="8.0.1" />
    <PackageReference Include="System.IO.Pipes.AccessControl" Version="5.0.0" />
    <PackageReference Include="System.IO.Ports" Version="8.0.0" />
    <PackageReference Include="System.Management" Version="8.0.0" />
    <PackageReference Include="System.ServiceProcess.ServiceController" Version="8.0.1" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="DraxService.Designer.cs">
      <DependentUpon>DraxService.cs</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="DraxService.resx">
      <DependentUpon>DraxService.cs</DependentUpon>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <None Update="ini\AdvMan.ini" CopyToOutputDirectory="PreserveNewest" />
    <None Update="ini\EMLMan.ini" CopyToOutputDirectory="PreserveNewest" />
    <None Update="ini\GenMan.ini" CopyToOutputDirectory="PreserveNewest" />
    <None Update="ini\MAXMan.ini" CopyToOutputDirectory="PreserveNewest" />
    <None Update="ini\Takman.ini" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- Copy the win-x64 native SQLite to the output root so the WiX harvest
       (DraxServiceSetup\Regenerate-Files.ps1) picks it up alongside the
       managed DLLs. .NET would otherwise probe runtimes\win-x64\native\
       only, but the installer would need to mirror that subtree. -->
  <Target Name="CopyNativeSQLiteToOutputRoot" AfterTargets="Build">
    <Copy SourceFiles="$(OutputPath)runtimes\win-x64\native\e_sqlite3.dll"
          DestinationFolder="$(OutputPath)"
          ContinueOnError="true" />
  </Target>

</Project>
