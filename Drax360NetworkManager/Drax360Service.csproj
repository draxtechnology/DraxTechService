<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net481</TargetFramework>
    <RootNamespace>DraxTechnology</RootNamespace>
    <AssemblyName>DraxTechnology</AssemblyName>
    <LangVersion>8.0</LangVersion>
    <StartupObject>DraxTechnology.Program</StartupObject>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <GenerateBindingRedirectsOutputType>true</GenerateBindingRedirectsOutputType>
    <Deterministic>true</Deterministic>
    <ProjectGuid>{040A3342-B92B-4794-B3F9-DB63B796BD30}</ProjectGuid>
    <!-- Properties/AssemblyInfo.cs is the source of truth — don't let SDK auto-generate one. -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="System.Configuration" />
    <Reference Include="System.Configuration.Install" />
    <Reference Include="System.Management" />
    <Reference Include="System.ServiceProcess" />
    <Reference Include="System.Web.Extensions" />
  </ItemGroup>

  <ItemGroup>
    <!-- EF Core 3.1.32 is the last version supporting .NET Framework 4.8.1 (netstandard2.0). -->
    <PackageReference Include="Microsoft.Data.Sqlite" Version="3.1.32" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="3.1.32" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="3.1.32" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="DraxService.Designer.cs">
      <DependentUpon>DraxService.cs</DependentUpon>
    </Compile>
    <Compile Update="ProjectInstaller.Designer.cs">
      <DependentUpon>ProjectInstaller.cs</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="DraxService.resx">
      <DependentUpon>DraxService.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="ProjectInstaller.resx">
      <DependentUpon>ProjectInstaller.cs</DependentUpon>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <None Update="ini\AdvMan.ini" CopyToOutputDirectory="PreserveNewest" />
    <None Update="ini\EMLMan.ini" CopyToOutputDirectory="PreserveNewest" />
    <None Update="ini\GenMan.ini" CopyToOutputDirectory="PreserveNewest" />
    <None Update="ini\MAXMan.ini" CopyToOutputDirectory="PreserveNewest" />
    <None Update="ini\Takman.ini" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
