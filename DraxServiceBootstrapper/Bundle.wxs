<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle Name="Drax Technology Service"
          Version="1.0.6"
          Manufacturer="Drax Technology"
          UpgradeCode="A2B9F47C-5E1D-4A6B-9D3C-7F2E8B4D5A6E"
          IconSourceFile="..\Drax360NetworkManager\DraxLogo.ico">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication Theme="hyperlinkLicense"
                                               ThemeFile="WixTheme.xml"
                                               LicenseUrl=""
                                               LogoFile="..\Drax360NetworkManager\DraxLogo.png"
                                               ShowVersion="yes" />
      <Payload SourceFile="..\Drax360NetworkManager\DraxLogo.ico" />
    </BootstrapperApplication>

    <!--
      The service is net10.0-windows and doesn't actually use WinForms/WPF,
      so strictly only the .NET 10 base runtime (Microsoft.NETCore.App) is
      required. We bundle the Desktop Runtime anyway because it's a strict
      superset (it installs both Microsoft.NETCore.App AND
      Microsoft.WindowsDesktop.App), which means the service + client
      installers share one runtime EXE — Mike only has to download it once
      per patch. Costs ~30 MB extra on the service install; worth it for
      build/maintenance ergonomics. Detection matches: present when the
      Desktop Runtime is installed.
    -->
    <!--
      Check for any installed 10.x Desktop Runtime by looking for a named value
      under the shared-fx key. Result="exists" on the key alone can return false
      on some machines even when a runtime is present (e.g. installed via a
      bundle that writes version values but not the parent key first). Checking
      for the specific patch value is reliable; if a *newer* patch is installed
      the value name will differ — we fall through to the EXE which then exits
      1638 (treated as success below).
    -->
    <util:RegistrySearch Id="SearchNetDesktop10"
                         Root="HKLM"
                         Key="SOFTWARE\dotnet\Setup\InstalledVersions\x64\sharedfx\Microsoft.WindowsDesktop.App"
                         Value="10.0.8"
                         Variable="NetDesktop10Present"
                         Result="exists" />

    <Chain>
      <!--
        .NET 10 Desktop Runtime — installed silently only when missing.
        Same EXE as DraxTechClient/DraxClientSetup; download once, drop a
        copy into both bootstrapper folders.

        REQUIRED BEFORE BUILDING:
          1. Go to https://dotnet.microsoft.com/download/dotnet/10.0
          2. Download the Windows x64 installer under ".NET Desktop
             Runtime 10.x.x".
          3. Place it in this folder (DraxServiceBootstrapper\). Microsoft's
             native filename already matches what SourceFile= expects, so no
             rename is needed.

        The file is embedded in the bundle at build time (~60 MB extra).
        To update to a newer patch, replace the file, update the SourceFile
        attribute below to the new filename, and rebuild.
      -->
      <ExePackage Id="NetDesktopRuntime10"
                  SourceFile="windowsdesktop-runtime-10.0.8-win-x64.exe"
                  DetectCondition="NetDesktop10Present"
                  InstallArguments="/install /quiet /norestart"
                  RepairArguments="/repair /quiet /norestart"
                  UninstallArguments="/uninstall /quiet /norestart"
                  Permanent="yes">
        <!-- 1638 = ERROR_PRODUCT_VERSION: a newer version is already installed — treat as success -->
        <ExitCode Value="1638" Behavior="success" />
      </ExePackage>

      <!-- Drax Service MSI -->
      <MsiPackage SourceFile="$(var.DraxServiceSetup.TargetPath)" />
    </Chain>
  </Bundle>

</Wix>
